post_install() {
  rm -f /usr/share/icons/hicolor/scalable/apps/bc250-control-center.svg
  gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor 2>/dev/null || true
}

post_upgrade() {
  post_install
}

post_remove() {
  gtk-update-icon-cache -q -t -f /usr/share/icons/hicolor 2>/dev/null || true
}
