#!/usr/bin/env sh
set -eu
XDG_DATA_BASE="${XDG_DATA_HOME:-$HOME/.local/share}"
for APP_DIR in \
  "${BC250_CONTROL_CENTER_DIR:-}" \
  "${MODO_JUEGO_RAM_DIR:-}" \
  "$XDG_DATA_BASE/bc250-control-center" \
  /usr/share/bc250-control-center \
  /usr/local/share/bc250-control-center \
  "$(CDPATH= cd -- "$(dirname -- "$0")/.." && pwd)"; do
  if [ -n "$APP_DIR" ] && [ -f "$APP_DIR/mvc/Daemon/control_centerd.py" ]; then
    cd "$APP_DIR"
    exec python3 -m mvc.Daemon.control_centerd "$@"
  fi
done
echo "No se encontro la instalacion de BC250 Control Center" >&2
exit 1
